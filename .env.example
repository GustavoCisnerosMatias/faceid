# .env — Variables de Entorno Sensibles para Sara Service
# INSTRUCCIONES:
# 1. Copiar este archivo como .env en el servidor
# 2. Completar con valores reales
# 3. Ejecutar: chmod 600 .env (solo propietario puede leer)
# 4. NO commitear el .env a Git (agregar a .gitignore)
#
# NOTA: Para desarrollo local, docker-compose.yml tiene valores por defecto
#       En producción, SIEMPRE usar archivo .env con valores reales

# ════════════════════════════════════════════════════════════════════════════════
# BASE DE DATOS - SQL SERVER
# ════════════════════════════════════════════════════════════════════════════════

# Servidor SQL Server (Producción: 192.168.95.43, Desarrollo: mies-sqlserver)
DB_HOST=192.168.95.43
DB_PORT=1433
DB_NAME=MiesData
DB_INSTANCE=SIIMIESBD

# Credenciales (mismo usuario para todas las BD)
DB_USER=appsiimies
DB_PASSWORD=Mie$2@16

# ════════════════════════════════════════════════════════════════════════════════
# SPRING BOOT / JAVA
# ════════════════════════════════════════════════════════════════════════════════

# Perfil activo (docker, production, development)
SPRING_PROFILES_ACTIVE=docker

# Puerto de la aplicación
SERVER_PORT=8083

# JVM Options
JAVA_OPTS=-Xmx512m -Xms256m -XX:+UseG1GC

# ════════════════════════════════════════════════════════════════════════════════
# LOGGING
# ════════════════════════════════════════════════════════════════════════════════

# Nivel de log raíz (ERROR, WARN, INFO, DEBUG, TRACE)
LOGGING_LEVEL_ROOT=INFO

# Nivel específico para Sara Service (más detallado)
LOGGING_LEVEL_EC_GOB_MDH_SARA=DEBUG

# ════════════════════════════════════════════════════════════════════════════════
# OPCIONAL: CONFIG SERVER
# ════════════════════════════════════════════════════════════════════════════════

# SPRING_CONFIG_URI=http://config-server:8888

# ════════════════════════════════════════════════════════════════════════════════
# OPCIONAL: SERVICE DISCOVERY EUREKA
# ════════════════════════════════════════════════════════════════════════════════

# EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-server:8761/eureka
